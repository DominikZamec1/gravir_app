# =====================================================================
#  Vzor konfigurace. Zkopíruj do .env a doplň hodnoty. .env se necommituje.
# =====================================================================

# --- Produkční MySQL (read replica, read-only uživatel) ---
PROD_DB_HOST=
PROD_DB_PORT=3306
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_DB_DATABASE=
PROD_DB_SSL_CA=

# --- Supabase ---
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_KEY=          # Settings -> API -> service_role (jen server/feed, do Storage uploadu)
SUPABASE_SCHEMA=gravir_app
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Přímé Postgres spojení.
# ⚠ POUŽIJ POOLER string (host ...pooler.supabase.com), NE "Direct connection"
#    (db.<ref>.supabase.co) – ten je jen IPv6 a z běžné sítě se nepřeloží.
SUPABASE_DB_URL=postgresql://postgres.<ref>:<heslo>@aws-0-<region>.pooler.supabase.com:5432/postgres
